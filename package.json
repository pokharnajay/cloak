{
  "name": "cloak",
  "version": "0.2.0",
  "description": "Cloak — Invisible overlay for Claude Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pokharnajay/cloak.git"
  },
  "bugs": {
    "url": "https://github.com/pokharnajay/cloak/issues"
  },
  "homepage": "https://github.com/pokharnajay/cloak#readme",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node -e \"const e={...process.env};delete e.ELECTRON_RUN_AS_NODE;require('child_process').execSync('npx electron-vite dev',{stdio:'inherit',env:e})\"",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build --mode production && electron-builder --mac --dir",
    "dist:dmg": "electron-vite build --mode production && electron-builder --mac dmg",
    "dist:win": "electron-vite build --mode production && electron-builder --win --dir",
    "doctor": "bash scripts/doctor.sh",
    "postinstall": "electron-builder install-app-deps && node -e \"if(process.platform==='darwin'){require('child_process').execSync('bash scripts/patch-dev-icon.sh',{stdio:'inherit'})}\""
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "framer-motion": "^12.35.1",
    "node-pty": "^1.1.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.cloak.app",
    "productName": "Cloak",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "identity": null,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Cloak uses your microphone to transcribe voice input locally with Whisper."
      }
    },
    "dmg": {
      "title": "Cloak",
      "icon": "resources/icon.icns",
      "background": "resources/dmg-background.png",
      "iconSize": 80,
      "contents": [
        { "x": 130, "y": 230 },
        { "x": 410, "y": 230, "type": "link", "path": "/Applications" }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "npmRebuild": false
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
